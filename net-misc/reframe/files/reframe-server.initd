#!/sbin/openrc-run
# Copyright 2025 Gentoo Authors
# Distributed under the terms of the GNU General Public License v2

description="ReFrame remote desktop server"

# Translated from upstream dists/reframe-server@.service.in.
# Upstream runs as User=<username> with RuntimeDirectory=reframe-session,
# AmbientCapabilities/CapabilityBoundingSet=CAP_NET_BIND_SERVICE,
# Environment=EGL_PLATFORM=surfaceless.
# OpenRC has no AmbientCapabilities equivalent, but the default VNC port
# (5933) is above 1024 so CAP_NET_BIND_SERVICE is not required.

instance="${RC_SVCNAME#*.}"
if [ "${instance}" = "${RC_SVCNAME}" ]; then
	instance=default
fi

: "${REFRAME_CONFBASEDIR:=/etc/reframe}"
: "${REFRAME_USER:=reframe}"
: "${REFRAME_GROUP:=reframe}"
: "${REFRAME_SOCKETDIR:=/run/reframe}"
: "${REFRAME_SESSION_SOCKETDIR:=/run/reframe-session}"
: "${REFRAME_LOGDIR:=/var/log/reframe}"

cfgfile="${REFRAME_CONFBASEDIR}/${instance}.conf"
if [ "${instance}" = default ] && [ ! -f "${cfgfile}" ] \
	&& [ -f "${REFRAME_CONFBASEDIR}/example.conf" ]; then
	cfgfile="${REFRAME_CONFBASEDIR}/example.conf"
fi

session_socket_file="${REFRAME_SESSION_SOCKETDIR}/${instance}.sock"

command="/usr/bin/reframe-server"
command_user="${REFRAME_USER}:${REFRAME_GROUP}"
command_args="--config=${cfgfile} --socket=${REFRAME_SOCKETDIR}/${instance}.sock --session-socket=${session_socket_file}"
supervisor=supervise-daemon
# Upstream: Environment=EGL_PLATFORM=surfaceless — required for framebuffer-only rendering.
supervise_daemon_args="-e EGL_PLATFORM=surfaceless"
pidfile="/run/${RC_SVCNAME}.pid"
output_log="${REFRAME_LOGDIR}/${RC_SVCNAME}.log"
error_log="${REFRAME_LOGDIR}/${RC_SVCNAME}.log"

depend() {
	# Upstream: Requires=reframe@%i.socket — the socket unit activates streamer.
	# In OpenRC we depend on the streamer service directly.
	if [ "${instance}" = default ]; then
		need reframe-streamer
	else
		need "reframe-streamer.${instance}"
	fi
	use net
}

start_pre() {
	if [ ! -f "${cfgfile}" ]; then
		eerror "Configuration file ${cfgfile} not found."
		eerror "Create one based on ${REFRAME_CONFBASEDIR}/example.conf"
		return 1
	fi

	# Upstream: RuntimeDirectory=reframe-session, RuntimeDirectoryMode=0755.
	# With User=<username>, systemd creates it owned by the service user.
	checkpath -d -m 0755 -o "${command_user}" "${REFRAME_SESSION_SOCKETDIR}"
	checkpath -d -m 0755 -o "${command_user}" "${REFRAME_LOGDIR}"
	checkpath -f -m 0644 -o "${command_user}" "${output_log}"

	# Clean up a stale session socket left behind by an unclean shutdown.
	[ ! -S "${session_socket_file}" ] || rm -f "${session_socket_file}"
}

stop_post() {
	[ ! -S "${session_socket_file}" ] || rm -f "${session_socket_file}"
}
