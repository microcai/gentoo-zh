# REW checks for upstream updates by default. Keep those checks disabled for a
# distro package so updates come through Portage only.
rew_abort() {
	echo "$@" >&2
	exit 1
}

if [[ -z ${HOME} ]]; then
	rew_abort "HOME is not set"
fi

mkdir -p "${HOME}/REW" || rew_abort "Failed to create ${HOME}/REW"

prefs_file="${HOME}/REW/rewprefs.txt"
prefs_tmp=$(mktemp "${prefs_file}.XXXXXX") || rew_abort "Failed to create preferences temp file"

if [[ -f ${prefs_file} ]]; then
	grep -v -e '^rew\.checkforupdates=' \
		-e '^rew\.showbetaversions=' \
		-e '^checkforupdates=' \
		-e '^showbetaversions=' "${prefs_file}" > "${prefs_tmp}"
	grep_status=${?}
	if [[ ${grep_status} -gt 1 ]]; then
		rew_abort "Failed to update ${prefs_file}"
	fi
fi

{
	printf '%s\n' 'rew.checkforupdates=false'
	printf '%s\n' 'rew.showbetaversions=false'
} >> "${prefs_tmp}" || rew_abort "Failed to write ${prefs_file}"

mv "${prefs_tmp}" "${prefs_file}" || rew_abort "Failed to install ${prefs_file}"

# Upstream's install4j launcher reads this file. java-pkg_dolauncher does not,
# so pass its non-comment options through gjl_java_args before launcher.bash
# executes Java.
app_home="${EPREFIX}/opt/rew"
vm_options=

if [[ -r ${app_home}/roomeqwizard.vmoptions ]]; then
	while IFS= read -r line; do
		case ${line} in
			''|'#'*) continue ;;
		esac
		vm_options+=" ${line}"
	done < "${app_home}/roomeqwizard.vmoptions"
fi

gjl_java_args="-Xms128m${vm_options}"
